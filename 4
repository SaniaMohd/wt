<!DOCTYPE html>
<html>
<head>
<style>
body { text-align:center; font-family:Arial; }
table { margin:auto; border-collapse:collapse; }
td, th { border:1px solid black; padding:10px; }
</style>
</head>

<body>

<h2>Billing</h2>

<table>
<tr><th>Product</th><th>Price</th><th>Qty</th><th>Subtotal</th></tr>

<tr><td>Item1</td><td>100</td>
<td><input type="number" id="q1" value="0" onchange="calc()"></td>
<td id="s1">0</td></tr>

<tr><td>Item2</td><td>200</td>
<td><input type="number" id="q2" value="0" onchange="calc()"></td>
<td id="s2">0</td></tr>

<tr><td>Item3</td><td>300</td>
<td><input type="number" id="q3" value="0" onchange="calc()"></td>
<td id="s3">0</td></tr>

<tr><td>Item4</td><td>400</td>
<td><input type="number" id="q4" value="0" onchange="calc()"></td>
<td id="s4">0</td></tr>

<tr><th colspan="3">Total</th><th id="total">0</th></tr>
</table>

<script>
function calc(){
  let p=[100,200,300,400];
  let q=[
    Math.max(0,q1.value),
    Math.max(0,q2.value),
    Math.max(0,q3.value),
    Math.max(0,q4.value)
  ];

  let s=q.map((v,i)=>v*p[i]);

  s1.innerText=s[0];
  s2.innerText=s[1];
  s3.innerText=s[2];
  s4.innerText=s[3];

  total.innerText=s.reduce((a,b)=>a+b,0);
}
</script>

</body>
</html>
